# Copy to .env and fill in your ClickHouse connection + credentials. .env is
# gitignored.   cp .env.example .env
# Quotes are optional (stripped on load). config/benchmark.properties holds only
# the run parameters (threads, ramp_up, duration, ...).
ch_host='your-instance.region.aws.clickhouse.cloud'
ch_port='8443'
ch_protocol='https'
ch_database='your_database'
ch_user='your_clickhouse_user'
ch_password='your_clickhouse_password'
